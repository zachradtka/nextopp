# Set to "true" to disable authentication (for local/self-hosted use)
AUTH_DISABLED=true

# Only needed if AUTH_DISABLED is not "true"
# Create a GitHub OAuth app at https://github.com/settings/developers
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_SECRET= # Generate with: npx auth secret

# Only needed for production (Turso)
# Sign up at https://turso.tech and create a database
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
